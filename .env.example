# Copy to .env and fill in. Do NOT commit .env.
SUPABASE_URL=https://urzuivoyaejhqfitfnrz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DOCS_BUCKET=documents
# Shared bearer token the app/n8n must send (Authorization: Bearer <DOCGEN_TOKEN>)
